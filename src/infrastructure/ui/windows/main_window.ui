  <property name="styleSheet">
   <string>/* BASE */
QWidget {
    background-color: #f9fafb;
    color: #374151;
    font-family: &quot;Segoe UI&quot;, &quot;Ubuntu&quot;, sans-serif;
    font-size: 14px;
}

/* LABELS INDICATIVOS */
QLabel#barcode_label {
    color: #6b7280;
    font-size: 13px;
    font-weight: 600;
    padding: 0 4px;
}

/* BARCODE INPUT */
QLineEdit#barcode_input {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 12px 16px;
    font-size: 16px;
    color: #374151;
}
QLineEdit#barcode_input:focus {
    border: 2px solid #4f46e5;
    padding: 11px 15px;
}

/* SEARCH RESULTS */
QListWidget#search_results {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    outline: none;
}
QListWidget#search_results::item {
    padding: 8px 12px;
    border-radius: 6px;
}
QListWidget#search_results::item:hover {
    background-color: #eef2ff;
    color: #4f46e5;
}
QListWidget#search_results::item:selected {
    background-color: #4f46e5;
    color: #ffffff;
}

/* CART TABLE */
QTableWidget#cart_table {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    gridline-color: #f3f4f6;
    outline: none;
}
QTableWidget#cart_table QHeaderView::section {
    background-color: #f9fafb;
    color: #6b7280;
    font-weight: bold;
    font-size: 11px;
    padding: 10px 12px;
    border: none;
    border-bottom: 1px solid #e5e7eb;
}
QTableWidget#cart_table::item {
    padding: 10px 12px;
    border: none;
}
QTableWidget#cart_table::item:selected {
    background-color: #eef2ff;
    color: #4f46e5;
}

/* TOTAL LABEL — elemento visualmente dominante */
QLabel#total_label {
    background-color: #4f46e5;
    color: #ffffff;
    border-radius: 16px;
    padding: 24px 16px;
    font-size: 40px;
    font-weight: 900;
    min-height: 100px;
}

/* BOTONES F1, F10 */
QPushButton#btn_new_sale,
QPushButton#btn_cash_close {
    background-color: #ffffff;
    color: #374151;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 20px 16px;
    font-size: 13px;
    font-weight: 600;
    min-height: 72px;
}
QPushButton#btn_new_sale:hover {
    background-color: #eef2ff;
    border-color: #4f46e5;
    color: #4f46e5;
}
QPushButton#btn_cash_close:hover {
    background-color: #fff5f5;
    border-color: #fca5a5;
    color: #dc2626;
}

/* BOTÓN COBRAR (F4) — acción principal */
QPushButton#btn_confirm {
    background-color: #10b981;
    color: #ffffff;
    border: none;
    border-radius: 12px;
    padding: 20px 16px;
    font-size: 15px;
    font-weight: 800;
    min-height: 72px;
}
QPushButton#btn_confirm:hover { background-color: #059669; }
QPushButton#btn_confirm:pressed { background-color: #047857; }

/* BOTÓN BORRAR ÍTEM */
QPushButton#btn_delete_item {
    background-color: #ffffff;
    color: #dc2626;
    border: 1px solid #fca5a5;
    border-radius: 8px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 600;
}
QPushButton#btn_delete_item:hover {
    background-color: #fff5f5;
    border-color: #dc2626;
}
QPushButton#btn_delete_item:disabled {
    color: #d1d5db;
    border-color: #e5e7eb;
}

/* HINT CANTIDAD MÚLTIPLE */
QLabel#barcode_hint_label {
    color: #6b7280;
    font-size: 11px;
    padding: 0 4px;
}

/* HINT ATAJOS CARRITO */
QLabel#hint_delete_label {
    color: #374151;
    font-size: 11px;
}

/* SCROLLBARS */
QScrollBar:vertical {
    background: transparent;
    width: 6px;
    margin: 0;
}
QScrollBar::handle:vertical {
    background: #d1d5db;
    border-radius: 3px;
    min-height: 24px;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
</string>
