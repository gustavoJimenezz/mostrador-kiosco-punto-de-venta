# Configuración del POS Web
# Copiar a /etc/kiosco-pos/config.env y ajustar los valores

# Base de datos local (SQLite por defecto)
DATABASE_URL=sqlite:////var/lib/kiosco-pos/pos.db

# Clave secreta para las cookies de sesión — CAMBIAR en producción
SECRET_KEY=cambiar-esta-clave-en-produccion

# Sincronización EOD al servidor remoto (opcional)
# Dejar vacío si no hay servidor remoto configurado
REMOTE_DATABASE_URL=

# Nivel de log (DEBUG | INFO | WARNING | ERROR)
POS_LOG_LEVEL=INFO

# Host y puerto del servidor (no cambiar en kiosco)
POS_HOST=127.0.0.1
POS_PORT=8000
